{
  "outputDir": "docs/superpowers",
  "stages": {
    "brainstorming": {
      "label": "需求探讨与方案设计",
      "model": "opencode-go/kimi-k2.7-code",
      "thinking": "high",
      "skill": "brainstorming",
      "interactive": true,
      "onFailure": "stop"
    },
    "writing-plans": {
      "label": "编写实施计划",
      "model": "My-Gemini/gemini-3.1-pro-preview",
      "thinking": "medium",
      "skill": "writing-plans",
      "interactive": true,
      "onFailure": "stop"
    },
    "executing-plans": {
      "label": "执行开发计划",
      "model": "opencode-go/qwen3.7-max",
      "thinking": "off",
      "skill": "subagent-driven-development",
      "onFailure": "continue"
    },
    "verification": {
      "label": "验证与检查",
      "model": "My-Gemini/gemini-3-flash-preview",
      "thinking": "low",
      "skill": "verification-before-completion",
      "onFailure": "continue",
      "e2e": {
        "devCommand": "cd snake-game && npm run dev",
        "baseUrl": "http://localhost:5173",
        "viewport": { "width": 1280, "height": 720 },
        "waitMs": 3000
      }
    }
  }
}
